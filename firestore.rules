rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public collection — safe artist data only (name, bio, practiceType, country, email)
    // Written by the artist when they save their profile
    // Readable by anyone — this is the only thing the public page reads
    match /public/{username} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null;
    }

    match /artists/{userId} {
      // Owner only — full access
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Artworks — owner full access + public can read public works
      match /artworks/{artworkId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if resource.data.isPublic != false;
      }

      // All other subcollections — owner only
      match /voices/{voiceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /wip/{wipId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /documents/{documentId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /{subcollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
